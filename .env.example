# PostgreSQL
POSTGRES_USER=neuroflow
POSTGRES_PASSWORD=neuroflow_secret_password
POSTGRES_DB=neuroflow
DATABASE_URL=postgresql://neuroflow:neuroflow_secret_password@localhost:5432/neuroflow

# Redis
REDIS_PASSWORD=redis_secret_password
REDIS_URL=redis://:redis_secret_password@localhost:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# OpenTelemetry
OTEL_SERVICE_NAME=neuroflow-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# API
API_HOST=0.0.0.0
API_PORT=8000
